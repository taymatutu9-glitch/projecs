   "source": [
    "# SQL query to count the number of movies in each genre\n",
    "query5 = \"SELECT `Genre(s)`, COUNT(*) AS movie_count FROM movies_full_cast_crew GROUP BY `Genre(s)`\"\n",
    "\n",
    "# Execute the query and store the results in a DataFrame\n",
    "df5 = pd.read_sql(query5, engine)\n",
    "\n",
    "# Print the DataFrame with the genre and movie count\n",
    "print(df5)\n"
