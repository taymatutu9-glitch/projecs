   "source": [
    "##MOVIES\n",
    "#removing null / missing values\n",
    "movies.fillna({\n",
    "    'Director': 'Unknown',\n",
    "    'Rating': '0.0',\n",
    "    'Language': 'Unknown',\n",
    "    'Genre(s)': 'Unknown',\n",
    "    'Release_Date': 'Unknown',\n",
    "    'Country_of_Origin': 'Unknown',\n",
    "    'Production_Company': 'Unknown',\n",
    "    'Budget' : '0.0',\n",
    "    'Gross_Worldwide':'0.0'\n",
    "}, inplace=True)\n",
    "for col in movies.columns:\n",
    "    if movies[col].map(type).eq(list).any():\n",
    "        movies[col] = movies[col].apply(lambda x: ', '.join(x) if isinstance(x, list) else x)\n",
    "# Remove duplicates\n",
    "movies.drop_duplicates(keep=False)\n",
    "# Standardize formats\n",
    "movies['Rating'] = movies['Rating'].astype(float)\n",
    "movies['Genre(s)'] = movies['Genre(s)'].str.replace(', ', '|')  #Split genres for easier filtering\n",
    "movies['Language'] = movies['Language'].apply(lambda x: ', '.join(x) if isinstance(x, list) else x)\n",
    "# Remove invalid rows \n",
    "movies = movies[movies['Title'].notnull() & (movies['Rating'] > 0)]\n",
    "print(movies)"
   ]
  },
