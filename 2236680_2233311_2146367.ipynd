   "source": [
    "# SQL Queries\n",
    "query_1 = \"SELECT COUNT(*) FROM movies_full_cast_crew;\"  # Query to count the number of movies\n",
    "query_2 = \"SELECT * FROM movies_full_cast_crew WHERE Name = 'Unknown';\"  # Query to display movies with the name 'Unknown'\n",
    "query_3 = \"SELECT DISTINCT Role_Type FROM movies_full_cast_crew;\"  # Query to display distinct role types\n",
    "\n",
    "# Execute queries and read results into DataFrame\n",
    "result_1 = pd.read_sql(query_1, engine)\n",
    "result_2 = pd.read_sql(query_2, engine)\n",
    "result_3 = pd.read_sql(query_3, engine)\n",
    "\n",
    "# Display results\n",
    "print(\"Number of movies:\", result_1)\n",
    "print(\"Movies with unknown names:\", result_2)\n",
    "print(\"Distinct role types:\", result_3)\n",
    "\n"
   ]
