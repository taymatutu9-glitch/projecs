   "source": [
    "##FULL_CAST_AND_CREW\n",
    "##making sure the the columns are UTF-8 \n",
    "full_cast_and_crew['Name'] = full_cast_and_crew['Name'].str.encode('utf-8').str.decode('utf-8')\n",
    "full_cast_and_crew['Role_Type'] = full_cast_and_crew['Role_Type'].str.encode('utf-8').str.decode('utf-8')\n",
    "full_cast_and_crew['Character_Position'] = full_cast_and_crew['Character_Position'].str.encode('utf-8').str.decode('utf-8')\n",
    "\n",
    "print(full_cast_and_crew)"
   ]
  },
