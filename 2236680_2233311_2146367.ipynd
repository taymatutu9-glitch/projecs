   "source": [
    "# SQL query to calculate the average release date of movies released after the year 2000\n",
    "query4 = \"SELECT AVG(release_date) AS average_release_date FROM movies_full_cast_crew WHERE release_date > 2000\"\n",
    "\n",
    "# Execute the query and store the result in a DataFrame\n",
    "df4 = pd.read_sql(query4, engine)\n",
    "\n",
    "# Print the resulting DataFrame with the average release date\n",
    "print(df4)\n",
    "\n"
   ]
  },
