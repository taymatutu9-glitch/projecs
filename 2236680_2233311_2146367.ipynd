    "#integrating MOVIES and FULL CAST AND CREW on movie_ID column\n",
    "import pandas as pd\n",
    "merged_df = pd.merge(movies, full_cast_and_crew, on='Movie_ID', how='left')\n",
    "merged_df.fillna({\n",
    "    'Name': 'Unknown',\n",
    "    'Role_Type': 'Unknown',\n",
    "    'Character_Position': 'Unknown'\n",
    "}, inplace=True)\n",
    "print(merged_df.head())"
   ]
