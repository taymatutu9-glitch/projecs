   "source": [
    "import pandas as pd\n",
    "\n",
    "##MOVIES\n",
    "# تنظيف العمود Release_Date لإزالة أي معلومات إضافية مثل النصوص داخل الأقواس\n",
    "movies['Release_Date'] = movies['Release_Date'].str.replace(r'\\(.*\\)', \"\", regex=True).str.strip()\n",
    "\n",
    "# التعامل مع التواريخ غير المتوافقة وتحويلها إلى صيغة مناسبة\n",
    "movies['Release_Date'] = pd.to_datetime(movies['Release_Date'], errors='coerce').dt.strftime('%Y-%m-%d')\n",
    "\n",
    "# قائمة بالأعمدة التي تحتاج إلى تحويل إلى UTF-8\n",
    "columns_to_encode = [\n",
    "    'Title', 'Genre(s)', 'Director', 'Country_of_Origin', \n",
    "    'Official_sites', 'Language', 'Filming_Locations', 'Production_Company'\n",
    "]\n",
    "\n",
    "# التأكد من أن الأعمدة الأخرى مشفرة بتنسيق UTF-8 مع التعامل مع القيم الفارغة\n",
    "for column in columns_to_encode:\n",
    "    movies[column] = movies[column].fillna(\"\").str.encode('utf-8').str.decode('utf-8')\n",
    "\n",
    "# عرض البيانات بعد التعديلات\n",
    "print(movies)\n"
   ]
  },
