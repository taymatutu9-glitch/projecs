   "source": [
    "from sklearn.preprocessing import StandardScaler, MinMaxScaler\n",
    "import pandas as pd\n",
    "\n",
    "# Replacing unwanted characters and changing type to float\n",
    "movies['Budget'] = movies['Budget'].replace({'[\\$,¥,€,₹,£,R,DEM\\xa0,KK,A,₩,.*,\\(.*\\), ]': '', 'estimated': ''}, regex=True).astype(float)\n",
    "movies['Gross_Worldwide'] = movies['Gross_Worldwide'].replace({'[\\$,¥,€,₹,R,DEM\\xa0,KK,£]': ''}, regex=True).astype(float)\n",
    "\n",
    "# Changing type to numeric\n",
    "movies['Rating'] = pd.to_numeric(movies['Rating'], errors='coerce')\n",
    "\n",
    "scaler_standard = StandardScaler()\n",
    "scaler_normalize = MinMaxScaler()\n",
    "\n",
    "# Standardization\n",
    "movies['Standardized_Rating'] = scaler_standard.fit_transform(movies[['Rating']])\n",
    "movies['Standardized_Budget'] = scaler_standard.fit_transform(movies[['Budget']])\n",
    "movies['Standardized_Gross_Worldwide'] = scaler_standard.fit_transform(movies[['Gross_Worldwide']])\n",
    "\n",
    "# Normalization\n",
    "movies['Normalized_Rating'] = scaler_normalize.fit_transform(movies[['Rating']])\n",
    "movies['Normalized_Budget'] = scaler_normalize.fit_transform(movies[['Budget']])\n",
    "movies['Normalized_Gross_Worldwide'] = scaler_normalize.fit_transform(movies[['Gross_Worldwide']])\n",
    "\n",
    "# Handling NaN values for numeric columns only\n",
    "numeric_columns = movies.select_dtypes(include=['number'])  # Select numeric columns\n",
    "movies[numeric_columns.columns] = numeric_columns.fillna(numeric_columns.mean())\n",
    "\n",
    "# Dealing with the scientific notation\n",
    "pd.set_option('display.float_format', '{:.1f}'.format)\n",
    "\n",
    "print(movies)"
   ]
  },
