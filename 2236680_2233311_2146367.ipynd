    "##FULL CAST AND CREW\n",
    "#checking for null values\n",
    "full_cast_and_crew = full_cast_and_crew[full_cast_and_crew['Name'].notnull()]\n",
    "#removing missing/null values\n",
    "full_cast_and_crew['Character_Position'].fillna('Unknown', inplace=True)\n",
    "full_cast_and_crew['Role_Type'].fillna('Crew Member', inplace=True)\n",
    "#removing duplicates\n",
    "full_cast_and_crew.drop_duplicates(inplace=True)\n",
    "print(full_cast_and_crew)"
   ]
