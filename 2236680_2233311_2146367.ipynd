   ],
   "source": [
    "# Find the minimum length of all lists\n",
    "length = [len(movie_ids), len(titles), len(ratings), len(genres)]\n",
    "\n",
    "# Use the minimum length to slice each list while creating the DataFrame\n",
    "movies_df = pd.DataFrame({\n",
    "    'Movie_ID': movie_ids,    #[:min_length],\n",
    "    'Title': titles,          #[:min_length], #[:min_length],\n",
    "    'Rating': ratings,  #[:min_length],\n",
    "    'Genre(s)': genres,    #[:min_length]\n",
    "})\n",
    "\n",
    "# Convert the movie details list of dictionaries to a DataFrame\n",
    "movie_details_df = pd.DataFrame(movies)\n",
    "\n",
    "# Combine both DataFrames\n",
    "movies = pd.concat([movies_df, movie_details_df.reset_index(drop=True)], axis=1)\n",
    "\n",
    "# Print the resulting DataFrame\n",
    "print(movies.head(10))\n",
    "print(length)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 7,
   "id": "0fb0c608-fe76-466d-9321-e0d269ee36bf",
   "metadata": {
    "tags": []
   },
   "outputs": [],
   "source": [
    "imdb_url='https://www.imdb.com/'\n",
    "cc_urls=[]\n",
    "for c in cast_and_crew_urls:\n",
    "    cc_urls.append(imdb_url+c)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 9,
   "id": "7f1d4b0d-f852-4f45-8244-9927ccd00862",
   "metadata": {
    "tags": []
   },
   "outputs": [],
   "source": [
    "data = []\n",
    "for movie_index, url in enumerate(cc_urls, start=1):\n",
    "    response = requests.get(url, headers=info)\n",
    "    soup = BeautifulSoup(response.text, 'html.parser')\n",
    "   \n",
    "    cast_table = soup.find('table', class_='cast_list')  # Locate the cast table\n",
    "    if cast_table:\n",
    "        rows = cast_table.find_all('tr', class_=['odd', 'even'])  # Rows for cast members\n",
    "        for row in rows:\n",
    "            # Extract actor name (second <td> contains the name)\n",
    "            name_cell = row.find_all('td')[1]  # Second <td>\n",
    "            actor_name = None\n",
    "            if name_cell:\n",
    "                name_tag = name_cell.find('a')  # <a> tag inside the <td>\n",
    "                if name_tag:\n",
    "                    actor_name = name_tag.get_text(strip=True)\n",
    "            \n",
    "            character_cell = row.find('td', class_='character')\n",
    "            character_name = None\n",
    "            if character_cell:\n",
    "                character_name = character_cell.get_text(strip=True).replace('\\n', '').split('/')[-1]\n",
    "            \n",
    "            if actor_name:  # Ensure actor_name is valid before appending\n",
    "                data.append({\n",
    "                    \"Movie_ID\": movie_index,\n",
    "                    \"Name\": actor_name,\n",
    "                    \"Role_Type\": \"Actor\",\n",
    "                    \"Character_Position\": character_name\n",
    "                })\n",
    "    \n",
    "    sections = soup.find_all('h4', class_='dataHeaderWithBorder')\n",
    "    for section in sections:\n",
    "        # Extract role type (e.g., \"Directed by\", \"Writing Credits\")\n",
    "        role_type = section.get_text(strip=True).replace(\":\", \"\")\n",
    "        \n",
    "        # Find the next table or list of names following the section\n",
    "        table = section.find_next('table')\n",
    "        if table:\n",
    "            rows = table.find_all('tr')\n",
    "            for row in rows:\n",
    "                name_tag = row.find('a')  # Find the <a> tag for the name\n",
    "                if name_tag:\n",
    "                    crew_name = name_tag.get_text(strip=True)\n",
    "                    data.append({\n",
    "                        \"Movie_ID\": movie_index,\n",
    "                        \"Name\": crew_name,\n",
    "                        \"Role_Type\": role_type,\n",
    "                        \"Character_Position\": None  # Only for actors\n",
    "                    })"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 10,
   "id": "bd359ce0-4bfa-40af-a73f-a3a9c4433df6",
